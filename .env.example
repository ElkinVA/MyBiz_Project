# =========== SECURITY ===========
SECRET_KEY=django-insecure-change-this-in-production-and-keep-it-secret
DEBUG=True

# =========== HOSTS ===========
ALLOWED_HOSTS=localhost,127.0.0.1

# =========== DATABASE ===========
# SQLite (по умолчанию)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL (раскомментировать для продакшена)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=mybiz_db
# DB_USER=mybiz_user
# DB_PASSWORD=strong_password_here
# DB_HOST=localhost
# DB_PORT=5432

# =========== EMAIL ===========
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@mybiz.com

# =========== CACHE ===========
REDIS_URL=redis://localhost:6379/1

# =========== SITE SETTINGS ===========
SITE_NAME=MyBiz Витрина
SITE_TAGLINE=Лучшие товары по доступным ценам
